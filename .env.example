# Database (Railway will auto-inject these on deploy)
DATABASE_URL="postgresql://user:password@localhost:5432/zume_dev"

# File Storage Paths
# Local development: relative path
# Railway: uses volume mount at /data
UPLOAD_DIR="/data/uploads"
STORAGE_BASE_PATH="/data"

# Authentication
SESSION_SECRET="generate-a-secret-key-here-min-32-chars"
SESSION_MAX_AGE="604800" # 7 days in seconds

# Anthropic API
ANTHROPIC_API_KEY="sk-ant-api03-..."

# App Config
BASE_URL="http://localhost:3000"
NODE_ENV="development"